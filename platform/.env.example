# コピーして .env を作成: cp platform/.env.example platform/.env
# （.env は .gitignore 済み。秘密情報をコミットしない — CLAUDE.md DO NOT 6）

# アプリ表示名。プロジェクト名は仮称のため、コードにハードコードせず
# 必ずこの設定値から参照する（docs/requirements.md §0）
VITE_APP_NAME=NAGAYA-BASE

# --- Supabase（次のイテレーションで接続。今は空でよい） ---
# Supabase ダッシュボード > Project Settings > API から取得
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# 注意: service_role キーは絶対にここ（クライアント側）へ書かない。
# service_role を扱ってよいのは Workers 内のみ（CLAUDE.md DO NOT 1）
